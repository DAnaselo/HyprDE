{
  "layer": "top",
  "position": "top",
  "mod": "dock",
  "exclusive": true,
  "passthrough": false,
  "height": 5,
  "height": 0,
  "modules-left": [
    "custom/menu",
    "gamemode",
    "clock"
  ],
  "modules-center": ["hyprland/window"],
  "modules-right": [
    "tray",
    "privacy",
    "mpris",
    "wireplumber",
    "custom/power"
  ],
  "hyprland/window": {
    "format": "{}"
  },
  "tray":{
    "icon-size": 20,
    "spacing": 10
  },
  "clock":{
    "interval": 60,
    "format": "{:%I:%M%p - %m/%d}",
    "on-click": "pkill -9 rofi",
    "timezone": "Asia/Jerusalem",
	  "tooltip-format": "<big>{:%A, %d.%B %Y }</big>\n<tt><small>{calendar}</small></tt>"
  },
  "custom/power":{
    "icon-size": 20,
    "spacing": 10,
    "format": "ŌŁś",
    "tooltip": false,
    "on-click": "rofi -show power-menu -modi power-menu:/home/anas/.config/rofi/rofi-power-menu"
  },
  "custom/menu":{
    "icon-size": 20,
    "spacing": 10,
    "tooltip": false,
    "format": "ŅŠé",
    "on-click": "rofi -show drun"
  },
  "gamemode": {
	  "format": "{glyph}",
	  "format-alt": "{glyph}  {count}",
	  "glyph": "¾░ōģ",
	  "hide-not-running": true,
	  "use-icon": false,
	  "icon-spacing": 0,
    "icon-size": 0,
	  "tooltip": true,
	  "tooltip-format": "Games running: {count}"
  },
  "privacy": {
	  "icon-spacing": 5,
	  "icon-size": 18,
    "spacing": 10,
	  "transition-duration": 250,
	  "modules": [
		  {
			"type": "screenshare",
			"tooltip": true,
			"tooltip-icon-size": 24
		  },
		  {
			"type": "audio-out",
			"tooltip": true,
			"tooltip-icon-size": 24
		  },
		  {
			"type": "audio-in",
			"tooltip": true,
			"tooltip-icon-size": 24
		  }
	  ]
  },
  "wireplumber":{
    "format": "{icon} {volume}%",
    "tooltip": false,
    "format-muted": "’Ć” Muted",
    "on-scroll-up": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%-",
    "scroll-step": 5,
    "on-click": "swaync-client -op",
    "format-icons": {
      "headphone": "’Ćź",
      "hands-free": "’Ćź",
      "headset": "’Ćź",
      "default": ["’Ć”", "’Ć¦", "’Ć©"]
    }
  },
  "mpris": {
    "format": "{player_icon}  {dynamic}",
    "format-paused": "{player_icon}  <i>{dynamic}</i>",
    "dynamic-order": ["title", "artist"],
    "dynamic-len": 40,
    "player-icons": {
      "spotify": "’å╝",
      "mpv": "’ģä",
      "vlc": "¾░Ģ╝",
      "firefox": "’ē®",
      "default": "’Ćü"
    },
    "status-icons": {
      "paused": "’üī",
      "playing": "’üŗ",
      "stopped": "’üŹ"
    },
    "tooltip-format": "{player}\n{artist} ŌĆö {title}",
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-click-middle": "playerctl previous",
    "scroll-step": 5
  }
}


